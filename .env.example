# Google AI Studio API Key (starts with AIzaSy)
OPENAI_API_KEY=AIzaSy_your_key_here
# Alternatively:
# GEMINI_API_KEY=AIzaSy_your_key_here

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/research_assistant
API_KEY=test-api-key-123
LANGSMITH_API_KEY=your-langsmith-key
LANGSMITH_PROJECT=research-assistant
DATA_DIR=/data

# Google Gemini compatibility models
OPENAI_MODEL_NAME=gemini-2.5-flash
EMBEDDING_MODEL_NAME=text-embedding-004
OPENAI_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai
